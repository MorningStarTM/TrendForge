# --- Database ---
POSTGRES_USER=trendforge
POSTGRES_PASSWORD=change-me
POSTGRES_DB=trendforge
DATABASE_URL=postgresql+psycopg://trendforge:change-me@postgres:5432/trendforge

# --- Redis / Celery ---
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
